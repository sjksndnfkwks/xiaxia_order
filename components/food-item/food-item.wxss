.food-item {
  display: flex;
  align-items: center;
  padding: 24rpx 28rpx;
  background: var(--c-bg-card);
  border-bottom: 1rpx solid var(--c-border-light);
  gap: 20rpx;
  position: relative;
}

/* ── 实验品标记 ── */
.exp-badge {
  position: absolute;
  top: 12rpx;
  left: 12rpx;
  font-size: 22rpx;
  opacity: 0.4;
  z-index: 1;
}

.food-img {
  width: 136rpx;
  height: 136rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
  background: var(--c-primary-pale);
}

.food-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.food-name {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--c-text-h);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.food-desc {
  font-size: 24rpx;
  color: var(--c-text-sub);
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* ── 便签式备注 ── */
.food-note-row {
  display: flex;
  align-items: center;
  gap: 6rpx;
  background: #FFFDE7;
  border-radius: 8rpx;
  padding: 6rpx 12rpx;
  border: 1rpx solid #FFE082;
  box-shadow: 2rpx 2rpx 0 rgba(255, 224, 130, 0.5);
}

.note-pin { font-size: 22rpx; flex-shrink: 0; }

.food-note-text {
  font-size: 22rpx;
  color: #795548;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.note-edit {
  font-size: 22rpx;
  flex-shrink: 0;
  opacity: 0.7;
}

.food-action {
  position: relative;
  width: 200rpx;
  height: 136rpx;
  flex-shrink: 0;
}

.qty-control {
  position: absolute;
  top: 50%;
  right: 60rpx;
  transform: translateY(-50%);
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.add-btn {
  position: absolute;
  top: 50%;
  right: 60rpx;
  transform: translateY(-50%);
}

.qty-btn {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: bold;
  line-height: 1;
}

.qty-btn.plus {
  background: var(--grad-primary);
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(91, 79, 216, 0.30);
}

.qty-btn.minus {
  background: var(--c-border);
  color: var(--c-text-sub);
}

.qty-num {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--c-text-h);
  min-width: 32rpx;
  text-align: center;
}

.add-btn {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  background: var(--grad-primary);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  font-weight: bold;
  line-height: 1;
  box-shadow: 0 4rpx 12rpx rgba(91, 79, 216, 0.30);
}

.note-btn {
  position: absolute;
  bottom: 4rpx;
  right: 60rpx;
  font-size: 20rpx;
  color: var(--c-text-hint);
  background: var(--c-bg);
  border: 1rpx solid var(--c-border-light);
  border-radius: 8rpx;
  padding: 4rpx 10rpx;
  line-height: 1.4;
}
