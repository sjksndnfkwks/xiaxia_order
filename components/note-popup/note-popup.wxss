.popup-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.4);
  z-index: 200;
  display: flex;
  align-items: flex-end;
}

.popup-sheet {
  background: var(--c-bg-card);
  border-radius: 32rpx 32rpx 0 0;
  padding: 40rpx 40rpx calc(40rpx + env(safe-area-inset-bottom));
  width: 100%;
}

.popup-header {
  margin-bottom: 32rpx;
}

.popup-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--c-text-h);
  display: block;
  margin-bottom: 8rpx;
}

.popup-hint {
  font-size: 24rpx;
  color: var(--c-text-sub);
}

.note-input {
  width: 100%;
  height: 160rpx;
  background: #FFFDE7;
  border-radius: 16rpx;
  padding: 24rpx;
  font-size: 28rpx;
  color: var(--c-text-body);
  border: 2rpx solid #FFE082;
  box-sizing: border-box;
}

.char-count {
  text-align: right;
  font-size: 22rpx;
  color: var(--c-text-hint);
  margin-top: 8rpx;
  margin-bottom: 32rpx;
}

.popup-footer {
  display: flex;
  gap: 24rpx;
}

.btn-cancel {
  flex: 1;
  height: 88rpx;
  border-radius: 50rpx;
  background: var(--c-bg);
  color: var(--c-text-sub);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 600;
  border: 1rpx solid var(--c-border);
}

.btn-confirm {
  flex: 2;
  height: 88rpx;
  border-radius: 50rpx;
  background: var(--c-primary);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 700;
  box-shadow: var(--shadow-btn);
}
