.bubble-row {
  display: flex;
  align-items: flex-end;
  margin-bottom: 32rpx;
  padding: 0 24rpx;
  gap: 16rpx;
}

.bubble-row.self {
  flex-direction: row-reverse;
}

.avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  flex-shrink: 0;
  background: var(--c-primary-pale);
}

.bubble-wrap {
  max-width: 68%;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.self .bubble-wrap {
  align-items: flex-end;
}

.bubble {
  border-radius: 24rpx;
  padding: 20rpx 28rpx;
}

.other .bubble {
  background: var(--c-bg-card);
  border-bottom-left-radius: 4rpx;
  box-shadow: var(--shadow-card);
}

.self .bubble {
  background: var(--grad-primary);
  border-bottom-right-radius: 4rpx;
}

.bubble-text {
  font-size: 30rpx;
  line-height: 1.6;
}

.other .bubble-text { color: var(--c-text-body); }
.self .bubble-text { color: #fff; }

.img-bubble {
  padding: 0;
  overflow: hidden;
}

.msg-img {
  width: 320rpx;
  height: 240rpx;
  display: block;
}

.video-bubble {
  padding: 0;
  overflow: hidden;
}

.msg-video {
  width: 320rpx;
  height: 240rpx;
  display: block;
}

.voice-bubble {
  display: flex;
  align-items: center;
  gap: 12rpx;
  min-width: 120rpx;
}

.voice-icon {
  font-size: 36rpx;
}

.voice-duration {
  font-size: 26rpx;
}

.other .voice-duration { color: var(--c-text-sub); }
.self .voice-duration { color: rgba(255,255,255,0.8); }

.bubble-time {
  font-size: 22rpx;
  color: var(--c-text-hint);
}
