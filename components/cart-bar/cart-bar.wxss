.stitch-fab {
  position: fixed;
  right: 32rpx;
  bottom: calc(120rpx + env(safe-area-inset-bottom));
  z-index: 100;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* ── CSS 史迪仔耳朵 ── */
.fab-ear-left,
.fab-ear-right {
  position: absolute;
  top: -18rpx;
  width: 30rpx;
  height: 38rpx;
  background: var(--grad-primary);
  border-radius: 50% 50% 20% 20%;
  z-index: -1;
  box-shadow: 0 2rpx 6rpx rgba(91, 79, 216, 0.3);
}

.fab-ear-left {
  left: 4rpx;
  transform: rotate(-18deg);
  transform-origin: bottom center;
}

.fab-ear-right {
  right: 4rpx;
  transform: rotate(18deg);
  transform-origin: bottom center;
}

/* ── 圆形头部 ── */
.fab-head {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: var(--grad-primary);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(91, 79, 216, 0.35);
  position: relative;
  border: 3rpx solid rgba(255, 255, 255, 0.3);
}

.fab-icon { font-size: 36rpx; }

/* ── 数量徽章（史迪仔鼻子）── */
.fab-badge {
  position: absolute;
  top: -4rpx;
  right: -4rpx;
  background: var(--c-accent);
  color: #fff;
  font-size: 18rpx;
  font-weight: 900;
  min-width: 32rpx;
  height: 32rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 5rpx;
  border: 2rpx solid #FFFFFF;
  box-shadow: 0 2rpx 6rpx rgba(255, 107, 157, 0.4);
}

.cart-placeholder {
  height: 40rpx;
}
