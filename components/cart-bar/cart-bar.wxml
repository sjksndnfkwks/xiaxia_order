<!-- 史迪仔购物车悬浮球 -->
<view class="stitch-fab" wx:if="{{totalCount > 0}}" bindtap="goCart">
  <!-- CSS 耳朵 -->
  <view class="fab-ear-left"></view>
  <view class="fab-ear-right"></view>
  <!-- 圆形头部 -->
  <view class="fab-head">
    <view class="fab-badge">{{totalCount}}</view>
  </view>
</view>

<view class="cart-placeholder" wx:if="{{totalCount > 0}}"></view>
