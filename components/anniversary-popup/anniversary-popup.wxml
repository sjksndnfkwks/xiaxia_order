<view class="ann-mask" wx:if="{{show}}" bindtap="onClose">
  <view class="ann-card {{entered ? 'entered' : ''}}" catchtap="">

    <!-- 关闭按钮 -->
    <view class="ann-close" bindtap="onClose">✕</view>

    <!-- 背景图片 -->
    <image
      class="ann-bg-img"
      src="{{anniversary.flowerImageUrl || '/assets/images/flower-default.png'}}"
      mode="aspectFill"
      bindtap="previewFlower"
    />

    <!-- 标题 -->
    <view class="ann-title-row">
      <text class="ann-title">{{anniversary.title}}</text>
    </view>

    <!-- 信件（有任意内容才显示） -->
    <block wx:if="{{anniversary.letterTo || anniversary.letterContent || anniversary.letterFrom}}">
      <scroll-view class="letter-scroll" scroll-y>
        <view class="letter-paper">
          <view class="letter-line" wx:if="{{anniversary.letterTo}}">
            <text class="letter-text">To {{anniversary.letterTo}}：</text>
          </view>
          <block wx:if="{{anniversary.letterContent}}">
            <view class="letter-line" wx:for="{{letterLines}}" wx:key="index">
              <text class="letter-text">{{item}}</text>
            </view>
          </block>
          <view class="letter-line letter-from" wx:if="{{anniversary.letterFrom}}">
            <text class="letter-text">From {{anniversary.letterFrom}}</text>
          </view>
        </view>
      </scroll-view>
    </block>

  </view>
</view>
