.ann-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(13, 31, 110, 0.7);
  z-index: 300;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
}

.ann-card {
  background: var(--c-bg-card);
  border-radius: 40rpx;
  width: 100%;
  max-height: 86vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  overflow: hidden;
  padding-bottom: 40rpx;
  transform: translateY(100vh);
  opacity: 0;
  transition: transform 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94), opacity 0.4s ease;
}

.ann-card.entered {
  transform: translateY(0);
  opacity: 1;
}

.flower-wrap {
  width: 100%;
  background: var(--grad-deep);
  padding: 48rpx 0 32rpx;
  display: flex;
  justify-content: center;
  position: relative;
  overflow: hidden;
}

.flower-wrap::after {
  content: '✨ 🐾 ✨';
  position: absolute;
  bottom: 12rpx;
  right: 20rpx;
  font-size: 22rpx;
  opacity: 0.3;
  letter-spacing: 6rpx;
}

.flower-img {
  width: 320rpx;
  height: 320rpx;
}

.ann-title-row {
  padding: 28rpx 40rpx 16rpx;
  text-align: center;
}

.ann-title {
  font-size: 40rpx;
  font-weight: 800;
  color: var(--c-text-h);
  letter-spacing: 2rpx;
}

.letter-scroll {
  flex: 1;
  width: 100%;
  max-height: 360rpx;
  padding: 0 40rpx;
  box-sizing: border-box;
}

.letter-wrap {
  position: relative;
  padding: 24rpx;
  background: var(--c-primary-pale);
  border-radius: 20rpx;
  border-left: 6rpx solid var(--c-primary);
}

.letter-quote {
  font-size: 60rpx;
  color: var(--c-primary);
  opacity: 0.25;
  font-family: Georgia, serif;
  line-height: 1;
}

.letter-quote.end {
  display: flex;
  justify-content: flex-end;
}

.letter-content {
  font-size: 28rpx;
  color: var(--c-text-body);
  line-height: 1.9;
  display: block;
  padding: 0 8rpx;
  white-space: pre-wrap;
}

.ann-close {
  margin-top: 32rpx;
  background: linear-gradient(135deg, #FF6B9D, #FF8FB5);
  color: #fff;
  font-size: 30rpx;
  font-weight: 700;
  padding: 24rpx 80rpx;
  border-radius: 50rpx;
  box-shadow: 0 6rpx 20rpx rgba(255, 107, 157, 0.35);
}
