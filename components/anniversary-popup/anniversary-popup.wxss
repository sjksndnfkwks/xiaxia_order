.ann-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  z-index: 300;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
}

.ann-card {
  background: var(--c-bg-card);
  border-radius: 32rpx;
  width: 100%;
  max-height: 88vh;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  position: relative;
  transform: scale(0.85);
  opacity: 0;
  transition: transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94), opacity 0.3s ease;
}

.ann-card.entered {
  transform: scale(1);
  opacity: 1;
}

/* 关闭按钮 */
.ann-close {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.35);
  color: #fff;
  font-size: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 10;
}

/* 背景图片 */
.ann-bg-img {
  width: 100%;
  height: 480rpx;
  display: block;
  flex-shrink: 0;
}

/* 标题 */
.ann-title-row {
  padding: 24rpx 32rpx 12rpx;
  background: var(--c-bg-card);
}

.ann-title {
  font-size: 34rpx;
  font-weight: 800;
  color: var(--c-text-h);
  letter-spacing: 2rpx;
}

/* 信件滚动区 */
.letter-scroll {
  max-height: 320rpx;
  flex-shrink: 0;
}

/* 信纸 */
.letter-paper {
  background: #FFFDF5;
  margin: 0 32rpx 32rpx;
  border-radius: 12rpx;
  overflow: hidden;
}

/* 每行信纸 */
.letter-line {
  padding: 0 24rpx;
  border-bottom: 1rpx solid #E8DEC8;
  min-height: 72rpx;
  display: flex;
  align-items: center;
}

.letter-line:first-child {
  border-top: 1rpx solid #E8DEC8;
}

.letter-from {
  justify-content: flex-end;
}

.letter-text {
  font-size: 28rpx;
  color: #5C4A2A;
  line-height: 1.6;
  display: block;
  width: 100%;
}

.letter-from .letter-text {
  text-align: right;
  color: #8B6F47;
}
