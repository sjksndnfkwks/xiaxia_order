.snack-card {
  background: var(--c-bg-card);
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: var(--shadow-card);
  display: flex;
  flex-direction: column;
  align-items: center;
  border: 1rpx solid var(--c-border-light);
}

.snack-img {
  width: 100%;
  height: 180rpx;
  background: var(--c-primary-pale);
}

.snack-name {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--c-text-h);
  padding: 12rpx 16rpx 8rpx;
  text-align: center;
  width: 100%;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  line-height: 1.4;
  box-sizing: border-box;
}

.snack-footer {
  padding: 0 16rpx 16rpx;
  width: 100%;
  display: flex;
  justify-content: center;
  box-sizing: border-box;
}

.qty-control {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.qty-btn {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: bold;
}

.qty-btn.plus {
  background: var(--grad-primary);
  color: #fff;
  box-shadow: 0 3rpx 10rpx rgba(27, 79, 216, 0.28);
}

.qty-btn.minus {
  background: var(--c-border);
  color: var(--c-text-sub);
}

.qty-num {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--c-text-h);
  min-width: 28rpx;
  text-align: center;
}

.add-btn {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: var(--grad-primary);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  font-weight: bold;
  box-shadow: 0 4rpx 14rpx rgba(27, 79, 216, 0.3);
}

.note-row {
  padding: 0 16rpx 16rpx;
  width: 100%;
  box-sizing: border-box;
}

.note-text {
  font-size: 22rpx;
  color: var(--c-accent);
  background: rgba(255, 107, 157, 0.1);
  border-radius: 8rpx;
  padding: 4rpx 12rpx;
  display: block;
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.note-text.hint {
  color: var(--c-text-hint);
  background: var(--c-bg);
}
