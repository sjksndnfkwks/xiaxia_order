.profile-header {
  position: relative;
  background: #FFFFFF;
  padding: 60rpx 40rpx 80rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  border-bottom: 1rpx solid var(--c-border-light);
}

.avatar-btn {
  width: 144rpx;
  height: 144rpx;
  padding: 0;
  margin: 0;
  background: transparent;
  border-radius: 50%;
  overflow: hidden;
  line-height: 1;
}

.avatar-btn::after { border: none; }

.avatar {
  width: 144rpx;
  height: 144rpx;
  border-radius: 50%;
  border: 4rpx solid var(--c-border);
  background: var(--c-primary-pale);
  display: block;
}

.nickname-input {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--c-text-h);
  letter-spacing: 1rpx;
  text-align: center;
  width: 400rpx;
  border-bottom: 1rpx solid var(--c-border-light);
  padding-bottom: 8rpx;
}

.nickname-placeholder {
  font-size: 28rpx;
  color: var(--c-text-hint);
  font-weight: 400;
}

.tap-hint {
  font-size: 22rpx;
  color: var(--c-text-hint);
}

.content-area {
  margin-top: 0;
  padding: 20rpx 24rpx calc(140rpx + env(safe-area-inset-bottom));
}

.section-card {
  background: var(--c-bg-card);
  border-radius: var(--r-card);
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: var(--shadow-card);
  border: 1rpx solid var(--c-border-light);
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--c-text-h);
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid var(--c-border-light);
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.loading-wrap {
  padding: 32rpx;
  text-align: center;
  color: var(--c-text-hint);
  font-size: 26rpx;
}

.empty-tip {
  padding: 32rpx;
  text-align: center;
  color: var(--c-text-hint);
  font-size: 26rpx;
}

.order-row {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--c-border-light);
}

.order-row:last-child { border-bottom: none; }

.order-row-left {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.order-no {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--c-text-h);
}

.order-no-line {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.order-buyer-avatar {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: var(--c-primary-pale);
  flex-shrink: 0;
}

.order-buyer-name {
  font-size: 24rpx;
  color: var(--c-text-sub);
  max-width: 180rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.order-delete {
  font-size: 24rpx;
  color: #E64545;
  padding: 6rpx 16rpx;
  border: 1rpx solid #E64545;
  border-radius: 8rpx;
  margin-left: 12rpx;
  line-height: 1.4;
}

.order-time {
  font-size: 22rpx;
  color: var(--c-text-hint);
}

.order-summary {
  font-size: 22rpx;
  color: var(--c-text-sub);
}

.order-row-right {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.order-arrow { font-size: 36rpx; color: var(--c-border); }

.quick-row, .admin-entry {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 16rpx 0;
  border-bottom: 1rpx solid var(--c-border-light);
}

.quick-row:last-child { border-bottom: none; }

.quick-icon, .admin-icon { font-size: 44rpx; }
.quick-label, .admin-label { flex: 1; font-size: 30rpx; color: var(--c-text-body); }
.logout-label { color: #E64545; }
.logout-row { border-bottom: none; }
.quick-arrow, .admin-arrow { font-size: 36rpx; color: var(--c-border); }

.admin-entry {
  background: var(--c-primary-pale);
  border-radius: var(--r-card);
  padding: 24rpx;
  border: 1rpx solid rgba(74, 144, 217, 0.3);
  border-bottom: 1rpx solid rgba(74, 144, 217, 0.3);
  margin-top: 8rpx;
}

.admin-label {
  font-weight: 600;
  color: var(--c-primary);
}
.admin-icon { color: var(--c-primary); }
.admin-arrow { color: var(--c-primary-light); }

/* ── 未登录态 ── */
.avatar-btn-guest {
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-guest {
  width: 144rpx;
  height: 144rpx;
  border-radius: 50%;
  border: 4rpx solid var(--c-border);
  background: #D8D8DC;
}

.nickname-guest-line {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  padding: 4rpx 0;
}

.nickname-guest {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--c-text-h);
}

.nickname-guest-hint {
  font-size: 22rpx;
  color: var(--c-text-hint);
}

.login-label { color: var(--c-primary); font-weight: 600; }
