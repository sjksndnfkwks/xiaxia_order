.profile-header {
  position: relative;
  background: var(--grad-deep);
  padding: 60rpx 40rpx 80rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  overflow: hidden;
}

.profile-header::after {
  content: '🐾 ✨ 🐾';
  position: absolute;
  bottom: 16rpx;
  right: 24rpx;
  font-size: 28rpx;
  opacity: 0.2;
  letter-spacing: 8rpx;
}

.header-bg {
  width: 100%;
  height: 100%;
  display: block;
}

.header-overlay {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}

.avatar {
  width: 144rpx;
  height: 144rpx;
  border-radius: 50%;
  border: 6rpx solid rgba(255,255,255,0.5);
  background: var(--c-primary-pale);
}

.nickname {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
  letter-spacing: 1rpx;
}

.tap-hint {
  font-size: 22rpx;
  color: rgba(255,255,255,0.6);
}

.content-area {
  margin-top: -32rpx;
  padding: 0 24rpx 40rpx;
}

.section-card {
  background: var(--c-bg-card);
  border-radius: var(--r-card);
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: var(--shadow-card);
  border: 1rpx solid var(--c-border-light);
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--c-text-h);
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid var(--c-border-light);
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.loading-wrap {
  padding: 32rpx;
  text-align: center;
  color: var(--c-text-hint);
  font-size: 26rpx;
}

.empty-tip {
  padding: 32rpx;
  text-align: center;
  color: var(--c-text-hint);
  font-size: 26rpx;
}

.order-row {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--c-border-light);
}

.order-row:last-child { border-bottom: none; }

.order-row-left {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.order-no {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--c-text-h);
}

.order-time {
  font-size: 22rpx;
  color: var(--c-text-hint);
}

.order-summary {
  font-size: 22rpx;
  color: var(--c-text-sub);
}

.order-row-right {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.order-arrow { font-size: 36rpx; color: var(--c-border); }

.quick-row, .admin-entry {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 16rpx 0;
  border-bottom: 1rpx solid var(--c-border-light);
}

.quick-row:last-child { border-bottom: none; }

.quick-icon, .admin-icon { font-size: 44rpx; }
.quick-label, .admin-label { flex: 1; font-size: 30rpx; color: var(--c-text-body); }
.quick-arrow, .admin-arrow { font-size: 36rpx; color: var(--c-border); }

.admin-entry {
  background: var(--grad-deep);
  border-radius: var(--r-card);
  padding: 24rpx;
  border: none;
  margin-top: 8rpx;
}

.admin-label {
  font-weight: 600;
  color: rgba(255,255,255,0.9);
}
.admin-icon { color: #fff; }
.admin-arrow { color: rgba(255,255,255,0.5); }
