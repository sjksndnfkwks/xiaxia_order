<!-- 顶部banner -->
<view class="profile-header">
  <button class="avatar-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
    <image class="avatar" src="{{userInfo.avatarUrl || '/assets/images/stitch-wave.png'}}" mode="aspectFill" />
  </button>
  <input
    class="nickname-input"
    type="nickname"
    value="{{userInfo.nickName}}"
    placeholder="点击修改昵称"
    placeholder-class="nickname-placeholder"
    bindchange="onNicknameBlur"
  />
  <text class="tap-hint">点头像换图，点名字改昵称</text>
</view>

<view class="content-area">
  <!-- 我的订单 -->
  <view class="section-card">
    <view class="section-title">我的订单</view>
    <view wx:if="{{loadingOrders}}" class="loading-wrap">
      <text>加载中...</text>
    </view>
    <view wx:elif="{{orders.length === 0}}" class="empty-tip">
      <text>还没有订单哦，快去点菜吧~</text>
    </view>
    <view wx:else>
      <view
        class="order-row"
        wx:for="{{orders}}"
        wx:key="_id"
        bindtap="goOrderDetail"
        data-id="{{item._id}}"
      >
        <view class="order-row-left">
          <view class="order-no-line">
            <text class="order-no">{{item.orderNo}}</text>
            <image class="order-buyer-avatar" src="{{item.userAvatarUrl || userInfo.avatarUrl || '/assets/images/stitch-wave.png'}}" mode="aspectFill" />
            <text class="order-buyer-name">{{item.userNickName || userInfo.nickName || ''}}</text>
          </view>
          <text class="order-time">{{item.createdAtStr}}</text>
          <text class="order-summary">菜{{item.totalFoodCount}}件 零食{{item.totalSnackCount}}件</text>
        </view>
        <view class="order-row-right">
          <view class="status-tag status-{{item.status}}">{{statusText[item.status]}}</view>
          <text class="order-delete" catchtap="deleteOrder" data-id="{{item._id}}">删除</text>
          <text class="order-arrow">›</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 想吃清单入口 -->
  <view class="section-card">
    <view class="quick-row" bindtap="goWishlist">
      <text class="quick-label">想吃清单</text>
      <text class="quick-arrow">›</text>
    </view>
    <view class="quick-row" bindtap="goAnnouncements">
      <text class="quick-label">公告</text>
      <text class="quick-arrow">›</text>
    </view>
  </view>

  <!-- 管理员入口 -->
  <view class="section-card" wx:if="{{isAdmin}}">
    <view class="admin-entry" bindtap="goAdmin">
      <text class="admin-label">进入管理后台</text>
      <text class="admin-arrow">›</text>
    </view>
  </view>
</view>
