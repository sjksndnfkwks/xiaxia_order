<view class="chat-page">
  <!-- 管理员侧边栏开关 -->
  <view wx:if="{{isAdmin}}" class="sidebar-toggle" bindtap="toggleSidebar">
    <text>{{sidebarOpen ? '✕' : '☰'}}</text>
  </view>
  <view wx:if="{{isAdmin && currentContact}}" class="conv-title">
    <image class="conv-title-avatar" src="{{currentContact.avatarUrl}}" mode="aspectFill" />
    <text class="conv-title-name">{{currentContact.displayName}}</text>
  </view>
  <view wx:elif="{{isAdmin}}" class="conv-title">
    <text class="conv-title-name conv-title-empty">未选择联系人</text>
  </view>

  <!-- 侧边栏 -->
  <view wx:if="{{isAdmin && sidebarOpen}}" class="sidebar-mask" bindtap="toggleSidebar"></view>
  <view wx:if="{{isAdmin}}" class="sidebar {{sidebarOpen ? 'sidebar-open' : ''}}" catchtap="noop">
    <view class="sidebar-header">
      <text class="sidebar-title">联系人</text>
    </view>
    <scroll-view class="sidebar-list" scroll-y>
      <view wx:if="{{contacts.length === 0}}" class="sidebar-empty">
        <text>还没有用户给你发过消息</text>
      </view>
      <view
        wx:for="{{contacts}}"
        wx:key="userId"
        class="sidebar-item {{currentUserId === item.userId ? 'sidebar-item-active' : ''}}"
        data-id="{{item.userId}}"
        bindtap="selectContact"
        bindlongpress="startEditRemark"
      >
        <image class="sidebar-avatar" src="{{item.avatarUrl}}" mode="aspectFill" />
        <view class="sidebar-info">
          <view class="sidebar-row1">
            <text class="sidebar-name">{{item.displayName}}</text>
            <text class="sidebar-time">{{item.lastTimeStr}}</text>
          </view>
          <view class="sidebar-row2">
            <text class="sidebar-preview">{{item.lastMessage}}</text>
            <view wx:if="{{item.unread > 0}}" class="sidebar-unread">{{item.unread}}</view>
          </view>
        </view>
      </view>
    </scroll-view>
    <view class="sidebar-hint">长按联系人可修改备注</view>
  </view>

  <!-- 备注编辑弹窗 -->
  <view wx:if="{{remarkEditing}}" class="remark-mask" bindtap="cancelEditRemark">
    <view class="remark-card" catchtap="noop">
      <view class="remark-title">设置备注</view>
      <text class="remark-sub">{{remarkEditing.nickName}}</text>
      <input
        class="remark-input"
        value="{{remarkInput}}"
        placeholder="输入备注名"
        bindinput="onRemarkInput"
        focus
      />
      <view class="remark-actions">
        <view class="remark-btn remark-cancel" bindtap="cancelEditRemark">取消</view>
        <view class="remark-btn remark-save" bindtap="saveRemark">保存</view>
      </view>
    </view>
  </view>

  <!-- 管理员未选联系人提示 -->
  <view wx:if="{{isAdmin && !currentUserId}}" class="no-contact-tip">
    <text class="no-contact-icon">💬</text>
    <text class="no-contact-text">从左侧选择一个联系人开始聊天</text>
  </view>

  <!-- 消息列表 -->
  <scroll-view
    wx:if="{{!isAdmin || currentUserId}}"
    class="msg-list {{isAdmin ? 'msg-list-admin' : ''}}"
    scroll-y
    scroll-into-view="{{scrollId}}"
    scroll-with-animation
  >
    <view style="height: 24rpx;"></view>
    <block wx:for="{{messages}}" wx:key="_id">
      <view class="time-separator" wx:if="{{item.showTime}}">
        <text>{{item.timeLabel}}</text>
      </view>
      <chat-bubble
        id="msg-{{item._id}}"
        msg="{{item}}"
        isSelf="{{item.senderId === myOpenid}}"
        avatarUrl="{{item.senderId === myOpenid ? myAvatar : (item.senderAvatar || peerAvatar)}}"
        multiSelect="{{multiSelect}}"
        selected="{{item.selected}}"
        bind:longpress="onBubbleLongPress"
        bind:select="onBubbleSelect"
        bind:openmerged="onOpenMerged"
      />
    </block>
    <view id="msg-bottom" style="height: 20rpx;"></view>
  </scroll-view>

  <!-- 关闭面板遮罩 -->
  <view class="panel-mask" wx:if="{{showEmoji || showExtra}}" bindtap="closePanels"></view>

  <!-- 引用预览条 -->
  <view class="quote-bar" wx:if="{{quotingMsg && !multiSelect}}">
    <text class="quote-bar-label">引用：</text>
    <text class="quote-bar-content">{{quotingMsg.content || '[媒体消息]'}}</text>
    <view class="quote-bar-close" bindtap="clearQuote">✕</view>
  </view>

  <!-- 输入工具栏（多选模式下隐藏） -->
  <view class="input-bar" wx:if="{{!multiSelect && (!isAdmin || currentUserId)}}">
    <view class="left-stack">
      <view wx:if="{{showFullscreenBtn}}" class="icon-btn fullscreen-btn" bindtap="openFullscreenEdit">
        <text>⛶</text>
      </view>
      <view class="icon-btn" bindtap="toggleVoice">
        <text>{{voiceMode ? '⌨️' : '🎙'}}</text>
      </view>
    </view>

    <textarea
      wx:if="{{!voiceMode}}"
      class="text-input"
      value="{{inputText}}"
      placeholder=""
      placeholder-class="input-placeholder"
      bindinput="onInput"
      bindconfirm="sendText"
      confirm-type="send"
      confirm-hold="{{false}}"
      auto-height
      show-confirm-bar="{{false}}"
      adjust-position
      cursor-spacing="20"
      maxlength="-1"
      bindlinechange="onLineChange"
    />

    <view
      wx:else
      class="voice-btn {{recording ? 'recording' : ''}}"
      bindtouchstart="startRecord"
      bindtouchend="stopRecord"
      bindtouchcancel="cancelRecord"
    >
      <text>{{recording ? '松开发送' : '按住说话'}}</text>
    </view>

    <view class="icon-btn" bindtap="toggleEmoji">
      <text>😊</text>
    </view>

    <view class="icon-btn" bindtap="toggleExtra">
      <text>⊕</text>
    </view>

    <view class="send-btn" bindtap="sendText" wx:if="{{inputText.length > 0}}">
      <text>发送</text>
    </view>
  </view>

  <!-- 多选操作栏 -->
  <view class="multiselect-bar" wx:if="{{multiSelect}}">
    <view class="ms-cancel" bindtap="exitMultiSelect">取消</view>
    <text class="ms-count">已选 {{selectedIds.length}} 条</text>
    <view class="ms-action ms-merge {{selectedIds.length < 2 ? 'ms-disabled' : ''}}" bindtap="mergeSelected">合并</view>
    <view class="ms-action ms-delete {{selectedIds.length === 0 ? 'ms-disabled' : ''}}" bindtap="deleteSelected">删除</view>
  </view>

  <!-- 录音浮层（按住说话时显示） -->
  <view wx:if="{{recording}}" class="record-overlay">
    <view class="record-mic">🎤</view>
    <view class="record-hint">松开发送</view>
  </view>

  <!-- 全屏编辑弹窗 -->
  <view wx:if="{{fullscreenEdit}}" class="fs-edit-mask">
    <view class="fs-edit-card">
      <view class="fs-edit-header">
        <view class="fs-edit-cancel" bindtap="cancelFullscreenEdit">取消</view>
        <text class="fs-edit-title">编辑消息</text>
        <view class="fs-edit-send" bindtap="sendFromFullscreen">发送</view>
      </view>
      <textarea
        class="fs-edit-textarea"
        value="{{fullscreenInput}}"
        bindinput="onFullscreenInput"
        focus="{{fullscreenEdit}}"
        placeholder="输入消息..."
        maxlength="-1"
        show-confirm-bar="{{false}}"
      />
    </view>
  </view>

  <!-- 长按浮层菜单 -->
  <view class="msg-menu-mask" wx:if="{{menuShow}}" bindtap="closeMenu" catchtouchmove="noop"></view>
  <view class="msg-menu" wx:if="{{menuShow}}" style="left: {{menuX}}px; top: {{menuY}}px;">
    <view class="menu-item" bindtap="menuCopy" wx:if="{{menuCanCopy}}">复制</view>
    <view class="menu-item" bindtap="menuQuote">引用</view>
    <view class="menu-item" bindtap="menuMultiSelect">多选</view>
    <view class="menu-item menu-danger" bindtap="menuDelete">删除</view>
  </view>

  <!-- 合并消息详情弹窗 -->
  <view class="merged-mask" wx:if="{{mergedDetail}}" bindtap="closeMergedDetail">
    <view class="merged-card" catchtap="noop">
      <view class="merged-header">
        <text class="merged-title">合并的 {{mergedDetail.items.length}} 条消息</text>
        <view class="merged-close" bindtap="closeMergedDetail">✕</view>
      </view>
      <scroll-view class="merged-scroll" scroll-y>
        <view class="merged-item" wx:for="{{mergedDetail.items}}" wx:key="index">
          <text class="merged-sender">{{item.senderName}}</text>
          <text class="merged-content">{{item.content}}</text>
        </view>
      </scroll-view>
    </view>
  </view>

  <!-- 表情面板 -->
  <view class="emoji-panel" wx:if="{{showEmoji && !multiSelect}}">
    <scroll-view class="emoji-scroll" scroll-y>
      <view class="emoji-grid">
        <view
          class="emoji-item"
          wx:for="{{emojiList}}"
          wx:key="index"
          bindtap="insertEmoji"
          data-emoji="{{item}}"
        >{{item}}</view>
      </view>
    </scroll-view>
    <!-- 退格键固定在底部 -->
    <view class="emoji-toolbar">
      <view class="emoji-backspace-btn" bindtap="deleteLastChar">⌫</view>
    </view>
  </view>

  <!-- 更多面板 -->
  <view class="extra-panel" wx:if="{{showExtra && !multiSelect}}">
    <view class="extra-btn" bindtap="sendImage">
      <view class="extra-label">图片</view>
    </view>
    <view class="extra-btn" bindtap="sendVideo">
      <view class="extra-label">视频</view>
    </view>
  </view>
</view>
