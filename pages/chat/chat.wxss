.chat-page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: var(--c-bg);
}

.msg-list {
  flex: 1;
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  transition: bottom 0.3s;
  padding-top: 88rpx;
}

.input-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: var(--c-bg-card);
  border-top: 1rpx solid var(--c-border-light);
  padding: 16rpx 24rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  z-index: 50;
}

.icon-btn {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  flex-shrink: 0;
}

.text-input {
  flex: 1;
  height: 72rpx;
  background: var(--c-bg);
  border-radius: 36rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: var(--c-text-body);
  border: 2rpx solid var(--c-border);
}

.voice-btn {
  flex: 1;
  height: 72rpx;
  background: var(--c-bg);
  border-radius: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: var(--c-text-sub);
  border: 2rpx solid var(--c-border);
  transition: all 0.2s;
}

.voice-btn.recording {
  background: var(--c-primary);
  color: #fff;
  border-color: var(--c-primary);
}

.send-btn {
  background: var(--grad-primary);
  color: #fff;
  font-size: 28rpx;
  font-weight: 700;
  padding: 16rpx 32rpx;
  border-radius: 36rpx;
  flex-shrink: 0;
  box-shadow: var(--shadow-btn);
}

.emoji-panel {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: var(--c-bg-card);
  border-top: 1rpx solid var(--c-border-light);
  padding: 24rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  z-index: 40;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
}

.emoji-item {
  font-size: 52rpx;
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.extra-panel {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: var(--c-bg-card);
  border-top: 1rpx solid var(--c-border-light);
  padding: 40rpx 60rpx;
  display: flex;
  gap: 60rpx;
  z-index: 40;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}

.extra-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.extra-icon {
  font-size: 60rpx;
  width: 120rpx;
  height: 120rpx;
  background: var(--c-primary-pale);
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.extra-label {
  font-size: 24rpx;
  color: var(--c-text-sub);
}
