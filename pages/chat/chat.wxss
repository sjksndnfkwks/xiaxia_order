.chat-page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: var(--c-bg);
  background-image:
    radial-gradient(circle at 20% 25%, rgba(255, 216, 90, 0.08) 0, transparent 180rpx),
    radial-gradient(circle at 85% 70%, rgba(94, 226, 211, 0.08) 0, transparent 220rpx);
}

.msg-list {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: calc(207rpx + env(safe-area-inset-bottom));
  padding-top: 88rpx;
}

/* ── 时间分隔符（微信风格） ── */
.time-separator {
  display: flex;
  justify-content: center;
  padding: 20rpx 0 12rpx;
}

.time-separator text {
  font-size: 22rpx;
  color: var(--c-text-hint);
  background: rgba(255, 255, 255, 0.6);
  padding: 6rpx 18rpx;
  border-radius: 10rpx;
  letter-spacing: 0.5rpx;
}

/* 透明遮罩，点击关闭面板 */
.panel-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: calc(207rpx + env(safe-area-inset-bottom));
  z-index: 150;
  background: transparent;
}

/* ── 引用预览条 ── */
.quote-bar {
  position: fixed;
  bottom: calc(207rpx + env(safe-area-inset-bottom));
  left: 0;
  right: 0;
  background: var(--c-yellow-pale);
  border-top: 2rpx solid var(--c-yellow);
  padding: 14rpx 24rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
  z-index: 350;
}

.quote-bar-label {
  font-size: 24rpx;
  color: var(--c-primary);
  font-weight: 700;
  flex-shrink: 0;
}

.quote-bar-content {
  flex: 1;
  font-size: 24rpx;
  color: #666;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.quote-bar-close {
  font-size: 28rpx;
  color: #999;
  flex-shrink: 0;
  padding: 0 8rpx;
}

/* ── 输入栏（位于 tabBar 之上） ── */
.input-bar {
  position: fixed;
  bottom: calc(107rpx + env(safe-area-inset-bottom));
  left: 0;
  right: 0;
  background: var(--c-bg-card);
  border-top: 1rpx solid var(--c-border);
  padding: 16rpx 20rpx;
  display: flex;
  align-items: flex-end;
  gap: 14rpx;
  z-index: 400;
  min-height: 100rpx;
  box-sizing: border-box;
}

.icon-btn {
  width: 68rpx;
  height: 68rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  flex-shrink: 0;
}

.left-stack {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex-shrink: 0;
  gap: 4rpx;
}

.fullscreen-btn {
  font-size: 32rpx;
  color: var(--c-primary);
}

/* 全屏编辑弹窗 */
.fs-edit-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.4);
  z-index: 950;
  display: flex;
  align-items: stretch;
  justify-content: stretch;
}

.fs-edit-card {
  flex: 1;
  background: var(--c-bg-card);
  display: flex;
  flex-direction: column;
  padding-top: env(safe-area-inset-top);
  padding-bottom: env(safe-area-inset-bottom);
}

.fs-edit-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid var(--c-border-light);
}

.fs-edit-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--c-text-h);
}

.fs-edit-cancel {
  font-size: 28rpx;
  color: var(--c-text-sub);
  padding: 8rpx 16rpx;
}

.fs-edit-send {
  font-size: 28rpx;
  color: #FFFFFF;
  background: #07C160;
  padding: 10rpx 28rpx;
  border-radius: 12rpx;
  font-weight: 700;
}

.fs-edit-textarea {
  flex: 1;
  width: 100%;
  padding: 28rpx 32rpx;
  font-size: 30rpx;
  line-height: 1.5;
  color: var(--c-text-h);
  box-sizing: border-box;
}

.text-input {
  flex: 1;
  min-height: 72rpx;
  max-height: 280rpx;
  background: var(--c-bg-cream);
  border-radius: 24rpx;
  padding: 18rpx 24rpx;
  font-size: 28rpx;
  line-height: 1.4;
  color: var(--c-text-h);
  border: 1rpx solid transparent;
  box-sizing: border-box;
}

.input-placeholder {
  color: var(--c-text-hint);
}

.voice-btn {
  flex: 1;
  height: 72rpx;
  background: var(--c-bg-cream);
  border-radius: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  color: var(--c-primary);
  border: 1rpx solid transparent;
  font-weight: 700;
}

.voice-btn.recording {
  background: var(--c-accent);
  color: #FFFFFF;
}

/* ── 录音浮层 ── */
.record-overlay {
  position: fixed;
  bottom: calc(207rpx + env(safe-area-inset-bottom));
  left: 0;
  right: 0;
  padding: 60rpx 60rpx 40rpx;
  background: linear-gradient(to top, rgba(0,0,0,0.55), rgba(0,0,0,0));
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 28rpx;
  z-index: 450;
}

.record-actions {
  display: flex;
  gap: 80rpx;
  align-items: flex-end;
}

.record-action {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.92);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  box-shadow: 0 8rpx 28rpx rgba(0, 0, 0, 0.25);
  transition: transform 0.15s ease-out, background 0.15s;
}

.record-action-active {
  background: var(--c-accent);
  transform: scale(1.18);
}

.record-action-active .record-action-label,
.record-action-active .record-action-icon {
  color: #FFFFFF;
}

.record-action-icon {
  font-size: 48rpx;
  line-height: 1;
}

.record-action-label {
  font-size: 22rpx;
  color: var(--c-text-h);
  font-weight: 600;
}

.record-hint {
  font-size: 24rpx;
  color: #FFFFFF;
  background: rgba(0, 0, 0, 0.5);
  padding: 8rpx 22rpx;
  border-radius: 24rpx;
}

/* ── 发送按钮：鸭子黄 ── */
.send-btn {
  height: 72rpx;
  padding: 0 32rpx;
  border-radius: 16rpx;
  background: #07C160;
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  box-shadow: 0 2rpx 6rpx rgba(7, 193, 96, 0.25);
}

/* ── 多选操作栏 ── */
.multiselect-bar {
  position: fixed;
  bottom: calc(107rpx + env(safe-area-inset-bottom));
  left: 0;
  right: 0;
  background: var(--c-bg-card);
  border-top: 1rpx solid var(--c-border);
  padding: 20rpx 32rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  z-index: 400;
  height: 100rpx;
  box-sizing: border-box;
}

.ms-cancel {
  font-size: 30rpx;
  color: var(--c-text-sub);
  padding: 12rpx 24rpx;
}

.ms-count {
  font-size: 28rpx;
  color: var(--c-primary);
  font-weight: 700;
}

.ms-action {
  font-size: 28rpx;
  padding: 12rpx 24rpx;
  font-weight: 700;
}

.ms-merge {
  color: var(--c-primary);
}

.ms-delete {
  color: var(--c-accent);
}

.ms-action.ms-disabled {
  color: var(--c-text-hint);
}

/* ── 长按浮层菜单 ── */
.msg-menu-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  z-index: 500;
  background: transparent;
}

.msg-menu {
  position: fixed;
  width: 160px;
  background: var(--c-bg-card);
  border-radius: 16rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.15);
  padding: 8rpx 0;
  z-index: 501;
  border: 1rpx solid var(--c-border-light);
}

.menu-item {
  padding: 20rpx 28rpx;
  font-size: 28rpx;
  color: var(--c-text-h);
  border-bottom: 1rpx solid var(--c-border-light);
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item.menu-danger {
  color: var(--c-accent);
}

/* ── 合并消息详情弹窗 ── */
.merged-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 60rpx 40rpx;
}

.merged-card {
  width: 100%;
  max-height: 80vh;
  background: var(--c-bg-card);
  border-radius: 24rpx;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.merged-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 28rpx;
  border-bottom: 1rpx solid var(--c-border-light);
}

.merged-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--c-text-h);
}

.merged-close {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--c-text-sub);
  font-size: 28rpx;
}

.merged-scroll {
  flex: 1;
  max-height: 60vh;
}

.merged-item {
  padding: 20rpx 28rpx;
  border-bottom: 1rpx solid var(--c-border-light);
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.merged-sender {
  font-size: 24rpx;
  color: var(--c-primary);
  font-weight: 600;
}

.merged-content {
  font-size: 28rpx;
  color: var(--c-text-h);
  line-height: 1.5;
}

/* ── 表情面板 ── */
.emoji-panel {
  position: fixed;
  bottom: calc(207rpx + env(safe-area-inset-bottom));
  left: 0;
  right: 0;
  background: var(--c-bg-cream);
  border-top: 1rpx solid var(--c-border);
  z-index: 200;
}

/* scroll-view 必须给固定高度才能滚动 */
.emoji-scroll {
  height: 300rpx;
  width: 100%;
}

.emoji-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  padding: 20rpx 24rpx 12rpx;
}

.emoji-item {
  font-size: 52rpx;
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 退格键固定在底部工具栏 */
.emoji-toolbar {
  border-top: 1rpx solid var(--c-border);
  padding: 12rpx 24rpx;
  display: flex;
  justify-content: flex-end;
  background: var(--c-bg-cream);
}

.emoji-backspace-btn {
  font-size: 40rpx;
  color: var(--c-primary);
  padding: 8rpx 24rpx;
  background: var(--c-bg-card);
  border-radius: 12rpx;
  font-weight: 700;
}

/* ── 更多面板 ── */
.extra-panel {
  position: fixed;
  bottom: calc(207rpx + env(safe-area-inset-bottom));
  left: 0;
  right: 0;
  background: var(--c-bg-cream);
  border-top: 1rpx solid var(--c-border);
  padding: 40rpx 60rpx 36rpx;
  display: flex;
  gap: 60rpx;
  z-index: 200;
}

.extra-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  width: 140rpx;
}

.extra-icon {
  font-size: 56rpx;
  width: 140rpx;
  height: 140rpx;
  background: var(--c-bg-card);
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: var(--shadow-card);
}

.extra-label {
  font-size: 28rpx;
  color: var(--c-text-h);
  font-weight: 600;
  width: 140rpx;
  text-align: center;
}

/* ── 管理员侧边栏 ── */
.sidebar-toggle {
  position: fixed;
  top: calc(env(safe-area-inset-top) + 20rpx);
  left: 24rpx;
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: var(--c-bg-card);
  box-shadow: var(--shadow-card);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: var(--c-primary);
  z-index: 700;
}

.conv-title {
  position: fixed;
  top: calc(env(safe-area-inset-top) + 20rpx);
  left: 110rpx;
  right: 24rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  gap: 14rpx;
  z-index: 600;
  background: rgba(253, 251, 245, 0.85);
  border-radius: 32rpx;
  padding: 0 22rpx;
}

.conv-title-avatar {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: var(--c-primary-pale);
}

.conv-title-name {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--c-text-h);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.conv-title-empty {
  color: var(--c-text-hint);
  font-weight: 400;
}

.msg-list-admin {
  padding-top: 110rpx;
}

.sidebar-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.35);
  z-index: 800;
}

.sidebar {
  position: fixed;
  top: 0;
  bottom: 0;
  left: 0;
  width: 400rpx;
  background: var(--c-bg-card);
  z-index: 801;
  transform: translateX(-110%);
  transition: transform 0.25s ease-out;
  display: flex;
  flex-direction: column;
  box-shadow: 4rpx 0 20rpx rgba(0, 0, 0, 0.08);
  padding-top: env(safe-area-inset-top);
}

.sidebar-open { transform: translateX(0); }

.sidebar-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx 20rpx;
  border-bottom: 1rpx solid var(--c-border-light);
}

.sidebar-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--c-text-h);
}

.sidebar-count {
  font-size: 24rpx;
  color: var(--c-text-hint);
  background: var(--c-bg-cream);
  padding: 4rpx 14rpx;
  border-radius: 20rpx;
}

.sidebar-header-right {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.sidebar-refresh {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: var(--c-bg-cream);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  color: var(--c-primary);
  font-weight: 700;
}

.sidebar-list {
  flex: 1;
  height: 0;
}

.sidebar-empty {
  padding: 60rpx 32rpx;
  text-align: center;
  font-size: 26rpx;
  color: var(--c-text-hint);
}

.sidebar-item {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 22rpx 28rpx;
  border-bottom: 1rpx solid var(--c-border-light);
}

.sidebar-item-active {
  background: var(--c-primary-pale);
}

.sidebar-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  flex-shrink: 0;
  background: var(--c-bg-cream);
}

.sidebar-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.sidebar-row1, .sidebar-row2 {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.sidebar-name {
  flex: 1;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--c-text-h);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.sidebar-time {
  font-size: 22rpx;
  color: var(--c-text-hint);
  flex-shrink: 0;
}

.sidebar-preview {
  flex: 1;
  font-size: 24rpx;
  color: var(--c-text-sub);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.sidebar-unread {
  min-width: 32rpx;
  height: 32rpx;
  padding: 0 8rpx;
  border-radius: 16rpx;
  background: #E64545;
  color: #FFFFFF;
  font-size: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.sidebar-hint {
  padding: 16rpx 28rpx;
  font-size: 22rpx;
  color: var(--c-text-hint);
  text-align: center;
  border-top: 1rpx solid var(--c-border-light);
}

.no-contact-tip {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
  color: var(--c-text-hint);
}

.no-contact-icon { font-size: 100rpx; }

.no-contact-text {
  font-size: 28rpx;
  color: var(--c-text-sub);
}

/* ── 备注编辑弹窗 ── */
.remark-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 900;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 60rpx;
}

.remark-card {
  width: 100%;
  background: var(--c-bg-card);
  border-radius: 24rpx;
  padding: 40rpx 36rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.remark-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--c-text-h);
}

.remark-sub {
  font-size: 24rpx;
  color: var(--c-text-hint);
}

.remark-input {
  height: 80rpx;
  background: var(--c-bg-cream);
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: var(--c-text-h);
  margin-top: 8rpx;
}

.remark-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 16rpx;
}

.remark-btn {
  flex: 1;
  height: 80rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 600;
}

.remark-cancel {
  background: var(--c-bg-cream);
  color: var(--c-text-sub);
}

.remark-save {
  background: var(--c-primary);
  color: #FFFFFF;
}
