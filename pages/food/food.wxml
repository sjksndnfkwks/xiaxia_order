<!-- 纪念日惊喜弹窗 -->
<anniversary-popup
  show="{{showAnniversary}}"
  anniversary="{{todayAnniversary}}"
  bind:close="onAnniversaryClose"
/>

<!-- 公告弹窗 -->
<announcement-popup
  show="{{showAnnouncement}}"
  announcement="{{todayAnnouncement}}"
  bind:close="onAnnouncementClose"
/>

<!-- 备注弹窗 -->
<note-popup
  show="{{notePopup.show}}"
  itemId="{{notePopup.itemId}}"
  itemName="{{notePopup.itemName}}"
  note="{{notePopup.note}}"
  bind:close="onNoteClose"
/>

<!-- 史迪仔加载动画 -->
<view class="stitch-loading" wx:if="{{loading}}">
  <view class="ears-wrap">
    <view class="ear"></view>
    <view class="ear"></view>
  </view>
  <view class="head-circle"></view>
  <text class="loading-text">加载中<text class="loading-dots"></text></text>
</view>

<!-- 主体 -->
<view class="food-wrapper" wx:else>
  <!-- 顶部搜索栏 -->
  <view class="food-search-bar">
    <view class="search-capsule">
      <input
        class="search-input"
        placeholder="今天想吃什么呀"
        placeholder-class="search-placeholder"
        value="{{searchText}}"
        bindinput="onSearch"
      />
    </view>
  </view>

  <!-- 双栏布局 -->
  <view class="food-container">
    <!-- 左侧分类导航 -->
    <scroll-view class="cat-sidebar" scroll-y scroll-into-view="{{activeCatId}}">
      <view
        wx:for="{{categories}}"
        wx:key="_id"
        id="cat-nav-{{item._id}}"
        class="cat-item {{activeCat === item._id ? 'active' : ''}}"
        bindtap="scrollToCategory"
        data-id="{{item._id}}"
      >
        <text class="cat-icon">{{item.icon}}</text>
        <text class="cat-name">{{item.name}}</text>
      </view>
    </scroll-view>

    <!-- 右侧菜品列表 -->
    <scroll-view
      class="food-list"
      scroll-y
      scroll-into-view="{{scrollTarget}}"
      bindscroll="onFoodScroll"
    >
      <view wx:if="{{searchText && searchResultEmpty}}">
        <view class="empty-cat search-empty">
          <text>没找到"{{searchText}}"相关的菜哦~</text>
        </view>
      </view>
      <view wx:else>
        <view
          wx:for="{{categories}}"
          wx:key="_id"
          id="section-{{item._id}}"
        >
          <view class="cat-section-title">{{item.icon}} {{item.name}}</view>
          <view wx:if="{{displayItemMap[item._id] && displayItemMap[item._id].length > 0}}">
            <food-item
              wx:for="{{displayItemMap[item._id]}}"
              wx:for-item="foodItem"
              wx:key="_id"
              item="{{foodItem}}"
              bind:editnote="onEditNote"
            />
          </view>
          <view class="empty-cat" wx:else>
            <text>暂时没有菜品哦~</text>
          </view>
        </view>
      </view>

      <view style="height: 160rpx;"></view>
    </scroll-view>
  </view>
</view>

<!-- 底部购物车 -->
<cart-bar />
