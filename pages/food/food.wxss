.food-container {
  display: flex;
  height: 100vh;
  background: var(--c-bg);
}

/* ── 左侧分类导航 ── */
.cat-sidebar {
  width: 168rpx;
  background: var(--c-bg-deep);
  flex-shrink: 0;
  height: 100vh;
}

.cat-item {
  padding: 28rpx 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  border-left: 6rpx solid transparent;
  transition: all 0.2s;
  position: relative;
}

.cat-item.active {
  background: var(--c-bg);
  border-left-color: var(--c-primary-light);
}

.cat-icon {
  font-size: 36rpx;
}

.cat-name {
  font-size: 22rpx;
  color: var(--c-text-hint);
  text-align: center;
  line-height: 1.3;
}

.cat-item.active .cat-name {
  color: var(--c-primary);
  font-weight: 600;
}

/* ── 右侧菜品列表 ── */
.food-list {
  flex: 1;
  height: 100vh;
  background: var(--c-bg);
}

.cat-section-title {
  font-size: 26rpx;
  font-weight: 700;
  color: var(--c-text-sub);
  background: var(--c-bg);
  padding: 20rpx 32rpx 12rpx;
  letter-spacing: 1rpx;
}

.empty-cat {
  padding: 40rpx;
  text-align: center;
  color: var(--c-text-hint);
  font-size: 26rpx;
}
