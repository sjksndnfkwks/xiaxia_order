.ann-list {
  height: 100vh;
  padding: 16rpx 24rpx;
  box-sizing: border-box;
  background: var(--c-bg);
}

.loading-wrap, .empty-tip {
  text-align: center;
  padding: 100rpx;
  color: var(--c-text-hint);
}

.ann-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 20rpx;
  background: var(--c-bg-card);
  border-radius: 16rpx;
  margin-bottom: 16rpx;
  border: 1rpx solid var(--c-border-light);
}

.ann-thumb {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
  background: var(--c-bg);
}

.ann-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.ann-date {
  font-size: 22rpx;
  color: var(--c-text-hint);
}

.ann-title {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--c-text-h);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.ann-preview {
  font-size: 22rpx;
  color: var(--c-text-sub);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.ann-actions {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  flex-shrink: 0;
}

.action-btn {
  font-size: 22rpx;
  padding: 10rpx 18rpx;
  border-radius: 20rpx;
  border: 1rpx solid var(--c-border);
  background: var(--c-bg);
}

.action-btn.edit { color: var(--c-primary); }
.action-btn.delete { color: var(--c-accent); }

.fab {
  position: fixed;
  right: 40rpx;
  bottom: 60rpx;
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: var(--c-primary);
  color: #fff;
  font-size: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 6rpx 20rpx rgba(29, 27, 59, 0.25);
}

.form-page {
  height: 100vh;
  padding: 24rpx;
  box-sizing: border-box;
  background: var(--c-bg);
}

.form-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.form-back {
  font-size: 28rpx;
  color: var(--c-primary);
}

.form-title {
  font-size: 32rpx;
  font-weight: 700;
}

.field-card {
  background: var(--c-bg-card);
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
  border: 1rpx solid var(--c-border-light);
}

.field-label {
  font-size: 24rpx;
  color: var(--c-text-sub);
  margin-bottom: 10rpx;
  display: block;
}

.field-input {
  width: 100%;
  height: 72rpx;
  font-size: 28rpx;
  color: var(--c-text-h);
  background: var(--c-bg);
  border-radius: 10rpx;
  padding: 0 20rpx;
  box-sizing: border-box;
}

.picker-field {
  display: flex;
  align-items: center;
}

.img-upload {
  width: 100%;
  height: 280rpx;
  background: var(--c-bg);
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.upload-preview { width: 100%; height: 100%; }

.upload-placeholder {
  color: var(--c-text-hint);
  font-size: 26rpx;
}

.ann-input {
  width: 100%;
  min-height: 200rpx;
  background: var(--c-bg);
  border-radius: 10rpx;
  padding: 16rpx 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  line-height: 1.7;
}

.char-count {
  display: block;
  text-align: right;
  font-size: 22rpx;
  color: var(--c-text-hint);
  margin-top: 8rpx;
}

.form-submit {
  margin-top: 24rpx;
  height: 88rpx;
  background: var(--c-primary);
  color: #fff;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 700;
}
