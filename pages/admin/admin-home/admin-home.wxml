<view class="admin-home">
  <!-- 欢迎头部 -->
  <view class="welcome-banner">
    <text class="welcome-title">管理后台</text>
    <text class="welcome-sub">你好，管理员！</text>
  </view>

  <!-- 数据概览 -->
  <view class="stats-row">
    <view class="stat-card" bindtap="goOrders">
      <text class="stat-num pending-num">{{pendingCount}}</text>
      <text class="stat-label">待处理订单</text>
    </view>
    <view class="stat-card" bindtap="goOrders">
      <text class="stat-num total-num">{{todayOrderCount}}</text>
      <text class="stat-label">今日订单</text>
    </view>
    <view class="stat-card" bindtap="goChat">
      <text class="stat-num msg-num">{{unreadMsgCount}}</text>
      <text class="stat-label">未读消息</text>
    </view>
  </view>

  <!-- 功能入口 -->
  <view class="menu-card">
    <view class="menu-item" bindtap="goCategories">
      <view class="menu-info">
        <text class="menu-title">分类管理</text>
        <text class="menu-desc">新增、编辑、删除菜品/零食分类</text>
      </view>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-divider"></view>
    <view class="menu-item" bindtap="goMenu">
      <view class="menu-info">
        <text class="menu-title">菜品/零食管理</text>
        <text class="menu-desc">添加、编辑、删除菜品和零食</text>
      </view>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-divider"></view>
    <view class="menu-item" bindtap="goOrders">
      <view class="menu-info">
        <text class="menu-title">订单管理</text>
        <text class="menu-desc">查看和处理所有订单</text>
      </view>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-divider"></view>
    <view class="menu-item" bindtap="goAnalytics">
      <view class="menu-info">
        <text class="menu-title">用户喜好分析</text>
        <text class="menu-desc">查看各菜品点单排行</text>
      </view>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-divider"></view>
    <view class="menu-item" bindtap="goAnniversaries">
      <view class="menu-info">
        <text class="menu-title">纪念日管理</text>
        <text class="menu-desc">设置惊喜日期、花束和信件</text>
      </view>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-divider"></view>
    <view class="menu-item" bindtap="goAnnouncements">
      <view class="menu-info">
        <text class="menu-title">公告管理</text>
        <text class="menu-desc">发布、编辑、删除公告</text>
      </view>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-divider"></view>
    <view class="menu-item" bindtap="goChat">
      <view class="menu-info">
        <text class="menu-title">聊天消息</text>
        <text class="menu-desc">查看和回复用户消息</text>
      </view>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <!-- 订阅消息管理 -->
  <view class="subscribe-card" bindtap="refreshSubscribe">
    <view class="sub-info">
      <text class="sub-title">续签通知权限</text>
      <text class="sub-desc">点击续签，确保收到订单和消息推送</text>
    </view>
  </view>
</view>
