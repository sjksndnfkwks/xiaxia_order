.filter-bar {
  background: var(--c-bg-deep);
  white-space: nowrap;
}

.filter-inner {
  display: inline-flex;
  padding: 16rpx 24rpx;
  gap: 16rpx;
}

.filter-btn {
  display: inline-flex;
  padding: 12rpx 28rpx;
  border-radius: 50rpx;
  background: rgba(255,255,255,0.12);
  color: var(--c-text-hint);
  font-size: 26rpx;
  flex-shrink: 0;
  border: 1rpx solid rgba(255,255,255,0.15);
}

.filter-btn.active {
  background: var(--c-primary-light);
  color: #fff;
  font-weight: 600;
  border-color: transparent;
}

.order-list {
  height: calc(100vh - 100rpx);
  padding: 20rpx;
  box-sizing: border-box;
}

.order-card {
  background: var(--c-bg-card);
  border-radius: var(--r-card);
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: var(--shadow-card);
  border: 1rpx solid var(--c-border-light);
}

.card-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.head-left {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.order-no {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--c-text-h);
}

.order-time {
  font-size: 22rpx;
  color: var(--c-text-hint);
}

.overall-note {
  background: rgba(255, 107, 157, 0.08);
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  margin-bottom: 16rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  border: 1rpx solid rgba(255, 107, 157, 0.2);
}

.note-label { font-size: 24rpx; color: var(--c-accent); font-weight: 600; }
.note-content { font-size: 24rpx; color: var(--c-accent); }

.sub-title {
  font-size: 26rpx;
  font-weight: 700;
  color: var(--c-primary);
  margin: 16rpx 0 8rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid var(--c-border-light);
}

.order-item {
  padding: 10rpx 0;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.order-item-name {
  font-size: 26rpx;
  color: var(--c-text-body);
}

.order-item-note {
  font-size: 22rpx;
  color: var(--c-accent);
  background: rgba(255, 107, 157, 0.1);
  border-radius: 6rpx;
  padding: 2rpx 10rpx;
  display: inline-block;
}

.card-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid var(--c-border-light);
  flex-wrap: wrap;
}

.action-btn {
  padding: 16rpx 32rpx;
  border-radius: 50rpx;
  font-size: 26rpx;
  font-weight: 600;
}

.action-btn.confirm { background: var(--grad-primary); color: #fff; box-shadow: var(--shadow-btn); }
.action-btn.done { background: linear-gradient(135deg, #1A6B3A, #27AE60); color: #fff; }
.action-btn.cancel { background: rgba(255, 107, 157, 0.12); color: var(--c-accent); }

.empty-tip {
  padding: 80rpx;
  text-align: center;
  color: var(--c-text-hint);
  font-size: 28rpx;
}
