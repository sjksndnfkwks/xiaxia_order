<!-- 状态筛选 -->
<scroll-view class="filter-bar" scroll-x>
  <view class="filter-inner">
    <view wx:for="{{filters}}" wx:key="val" class="filter-btn {{activeFilter === item.val ? 'active' : ''}}" bindtap="setFilter" data-val="{{item.val}}">
      {{item.label}}
    </view>
  </view>
</scroll-view>

<scroll-view class="order-list" scroll-y>
  <view class="loading-wrap" wx:if="{{loading}}"><text>加载中...</text></view>
  <view wx:else>
    <!-- 订单卡片 -->
    <view class="order-card" wx:for="{{orders}}" wx:key="_id" bindtap="toggleExpand" data-id="{{item._id}}">
      <!-- 卡片头部 -->
      <view class="card-head">
        <view class="head-left">
          <text class="order-no">{{item.orderNo}}</text>
          <text class="order-time">{{item.createdAtStr}}</text>
        </view>
        <view class="status-tag status-{{item.status}}">{{statusText[item.status]}}</view>
      </view>

      <!-- 整体备注 -->
      <view class="overall-note" wx:if="{{item.overallNote}}">
        <text class="note-label">整体备注：</text>
        <text class="note-content">{{item.overallNote}}</text>
      </view>

      <!-- 展开详情 -->
      <view wx:if="{{expandedId === item._id}}">
        <!-- 菜品 -->
        <view wx:if="{{item.foodItems && item.foodItems.length > 0}}">
          <view class="sub-title">菜品</view>
          <view class="order-item" wx:for="{{item.foodItems}}" wx:for-item="fi" wx:key="itemId">
            <text class="order-item-name">{{fi.name}} × {{fi.quantity}}</text>
            <text class="order-item-note" wx:if="{{fi.note}}">备注：{{fi.note}}</text>
          </view>
        </view>
        <!-- 零食 -->
        <view wx:if="{{item.snackItems && item.snackItems.length > 0}}">
          <view class="sub-title">零食</view>
          <view class="order-item" wx:for="{{item.snackItems}}" wx:for-item="si" wx:key="itemId">
            <text class="order-item-name">{{si.name}} × {{si.quantity}}</text>
            <text class="order-item-note" wx:if="{{si.note}}">备注：{{si.note}}</text>
          </view>
        </view>

        <!-- 操作按钮 -->
        <view class="card-actions">
          <view class="action-btn confirm" wx:if="{{item.status === 'pending'}}" catchtap="confirmOrder" data-id="{{item._id}}">确认订单</view>
          <view class="action-btn done" wx:if="{{item.status === 'confirmed'}}" catchtap="doneOrder" data-id="{{item._id}}">标为完成</view>
          <view class="action-btn cancel" wx:if="{{item.status !== 'done' && item.status !== 'cancelled'}}" catchtap="cancelOrder" data-id="{{item._id}}">取消订单</view>
        </view>
      </view>
    </view>

    <view class="empty-tip" wx:if="{{orders.length === 0}}">暂无订单</view>
  </view>
  <view style="height: 60rpx;"></view>
</scroll-view>
