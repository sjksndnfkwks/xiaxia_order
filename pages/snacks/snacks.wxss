.cat-filter {
  background: #FFFFFF;
  white-space: nowrap;
  border-bottom: 1rpx solid var(--c-border-light);
}

.cat-filter-inner {
  display: inline-flex;
  padding: 20rpx 24rpx;
  gap: 16rpx;
}

.cat-tag {
  display: inline-flex;
  align-items: center;
  padding: 12rpx 28rpx;
  border-radius: 50rpx;
  background: #F0F0F0;
  color: #888888;
  font-size: 26rpx;
  white-space: nowrap;
  flex-shrink: 0;
  border: 1rpx solid transparent;
  transition: all 0.2s;
}

.cat-tag.active {
  background: var(--grad-accent);
  color: #FFFFFF;
  font-weight: 600;
  border-color: transparent;
  box-shadow: 0 4rpx 12rpx rgba(155, 89, 182, 0.30);
}

.snack-scroll {
  height: calc(100vh - 100rpx);
}

.snack-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 24rpx;
  gap: 20rpx;
}

.snack-cell {
  width: calc(33.33% - 14rpx);
}
