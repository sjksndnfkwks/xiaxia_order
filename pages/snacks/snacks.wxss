.cat-filter {
  background: var(--c-bg-deep);
  white-space: nowrap;
}

.cat-filter-inner {
  display: inline-flex;
  padding: 20rpx 24rpx;
  gap: 16rpx;
}

.cat-tag {
  display: inline-flex;
  align-items: center;
  padding: 12rpx 28rpx;
  border-radius: 50rpx;
  background: rgba(255,255,255,0.12);
  color: var(--c-text-hint);
  font-size: 26rpx;
  white-space: nowrap;
  flex-shrink: 0;
  border: 1rpx solid rgba(255,255,255,0.15);
}

.cat-tag.active {
  background: var(--c-primary-light);
  color: #fff;
  font-weight: 600;
  border-color: transparent;
}

.snack-scroll {
  height: calc(100vh - 100rpx);
}

.snack-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 24rpx;
  gap: 20rpx;
}

.snack-cell {
  width: calc(33.33% - 14rpx);
}
