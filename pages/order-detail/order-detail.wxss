.detail-page {
  padding: 24rpx;
  background: var(--c-bg);
  min-height: 100vh;
}

.status-card {
  background: var(--grad-deep);
  border-radius: var(--r-card);
  padding: 48rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 24rpx;
  position: relative;
  overflow: hidden;
}

.status-card::after {
  content: '🐾 ✨';
  position: absolute;
  bottom: 12rpx;
  right: 20rpx;
  font-size: 24rpx;
  opacity: 0.2;
  letter-spacing: 6rpx;
}

.status-icon { font-size: 80rpx; }

.status-label {
  font-size: 40rpx;
  font-weight: 800;
  color: #fff;
}

.order-no-text {
  font-size: 24rpx;
  color: rgba(255,255,255,0.8);
}

.order-time-text {
  font-size: 22rpx;
  color: rgba(255,255,255,0.6);
}

.info-card {
  background: var(--c-bg-card);
  border-radius: var(--r-card);
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: var(--shadow-card);
  border: 1rpx solid var(--c-border-light);
}

.card-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--c-text-h);
  padding-bottom: 16rpx;
  margin-bottom: 20rpx;
  border-bottom: 1rpx solid var(--c-border-light);
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.overall-note-text {
  font-size: 28rpx;
  color: var(--c-accent);
  line-height: 1.8;
  background: rgba(255, 107, 157, 0.08);
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  border: 1rpx solid rgba(255, 107, 157, 0.2);
}

.item-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 16rpx 0;
  border-bottom: 1rpx solid var(--c-border-light);
}

.item-row:last-child { border-bottom: none; }

.item-img {
  width: 100rpx;
  height: 100rpx;
  border-radius: 12rpx;
  background: var(--c-primary-pale);
  flex-shrink: 0;
}

.item-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.item-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--c-text-h);
}

.item-note {
  font-size: 22rpx;
  color: var(--c-accent);
  background: rgba(255, 107, 157, 0.1);
  border-radius: 8rpx;
  padding: 4rpx 12rpx;
  display: inline-block;
}
