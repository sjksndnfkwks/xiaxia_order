.detail-page {
  padding: 24rpx;
  background: var(--c-bg);
  min-height: 100vh;
}

.status-card {
  background: #FFFFFF;
  border-radius: var(--r-card);
  padding: 48rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-card);
  border: 1rpx solid var(--c-border-light);
}

.status-icon { font-size: 80rpx; }

.status-label {
  font-size: 40rpx;
  font-weight: 800;
  color: var(--c-text-h);
}

.order-no-text {
  font-size: 24rpx;
  color: var(--c-text-sub);
}

.order-time-text {
  font-size: 22rpx;
  color: var(--c-text-hint);
}

.info-card {
  background: var(--c-bg-card);
  border-radius: var(--r-card);
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: var(--shadow-card);
  border: 1rpx solid var(--c-border-light);
}

.card-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--c-text-h);
  padding-bottom: 16rpx;
  margin-bottom: 20rpx;
  border-bottom: 1rpx solid var(--c-border-light);
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.overall-note-text {
  font-size: 28rpx;
  color: #E65100;
  line-height: 1.8;
  background: #FFFDE7;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  border: 1rpx solid #FFE082;
}

.item-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 16rpx 0;
  border-bottom: 1rpx solid var(--c-border-light);
}

.item-row:last-child { border-bottom: none; }

.item-img {
  width: 100rpx;
  height: 100rpx;
  border-radius: 12rpx;
  background: var(--c-primary-pale);
  flex-shrink: 0;
}

.item-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.item-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--c-text-h);
}

.item-note {
  font-size: 22rpx;
  color: #E65100;
  background: #FFFDE7;
  border-radius: 8rpx;
  padding: 4rpx 12rpx;
  display: inline-block;
  border: 1rpx solid #FFE082;
}

.qty-control {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex-shrink: 0;
}

.qty-btn {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: var(--c-bg);
  border: 1rpx solid var(--c-border);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: var(--c-primary);
  font-weight: 700;
}

.qty-num {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--c-text-h);
  min-width: 40rpx;
  text-align: center;
}

.note-edit-input {
  width: 100%;
  min-height: 100rpx;
  background: #FFFDE7;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  color: var(--c-text-body);
  border: 1rpx solid #FFE082;
  box-sizing: border-box;
  line-height: 1.6;
}

.cancelled-card {
  background: #f5f5f5;
  border-color: var(--c-border-light);
}

.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 32rpx calc(20rpx + env(safe-area-inset-bottom));
  background: var(--c-bg-card);
  border-top: 1rpx solid var(--c-border-light);
  display: flex;
  gap: 24rpx;
  box-shadow: 0 -2rpx 12rpx rgba(0,0,0,0.06);
}

.btn-cancel {
  flex: 1;
  height: 88rpx;
  border-radius: 44rpx;
  border: 1rpx solid var(--c-border);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  color: var(--c-text-sub);
  font-weight: 600;
}

.btn-save {
  flex: 2;
  height: 88rpx;
  border-radius: 44rpx;
  background: var(--c-primary);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  color: #fff;
  font-weight: 700;
}

.btn-save.disabled {
  background: var(--c-border);
  color: var(--c-text-hint);
}
