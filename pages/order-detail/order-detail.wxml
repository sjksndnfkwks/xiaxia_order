<view class="loading-wrap" wx:if="{{loading}}">
  <text>加载中...</text>
</view>

<view wx:elif="{{order.status === 'cancelled'}}" class="detail-page">
  <view class="status-card cancelled-card">
    <text class="status-label">已取消</text>
    <text class="order-no-text">订单号：{{order.orderNo}}</text>
    <text class="order-time-text">{{order.createdAtStr}}</text>
  </view>
</view>

<view wx:else class="detail-page">
  <!-- 状态卡片 -->
  <view class="status-card">
    <text class="status-label">{{statusText[order.status]}}</text>
    <text class="order-no-text">订单号：{{order.orderNo}}</text>
    <text class="order-time-text">{{order.createdAtStr}}</text>
  </view>

  <!-- 整体备注（可编辑） -->
  <view class="info-card">
    <view class="card-title">备注</view>
    <textarea
      class="note-edit-input"
      value="{{editNote}}"
      placeholder="给做菜的留个言~"
      maxlength="100"
      bindinput="onNoteInput"
    />
  </view>

  <!-- 菜品 -->
  <view class="info-card" wx:if="{{foodItems.length > 0}}">
    <view class="card-title">菜品</view>
    <view class="item-row" wx:for="{{foodItems}}" wx:key="itemId">
      <image class="item-img" src="{{item.imageUrl}}" mode="aspectFill" />
      <view class="item-info">
        <text class="item-name">{{item.name}}</text>
        <text class="item-note" wx:if="{{item.note}}">{{item.note}}</text>
      </view>
      <view class="qty-control">
        <view class="qty-btn" catchtap="minus" data-type="food" data-index="{{index}}">－</view>
        <text class="qty-num">{{item.quantity}}</text>
        <view class="qty-btn" catchtap="plus" data-type="food" data-index="{{index}}">＋</view>
      </view>
    </view>
  </view>

  <!-- 零食 -->
  <view class="info-card" wx:if="{{snackItems.length > 0}}">
    <view class="card-title">零食</view>
    <view class="item-row" wx:for="{{snackItems}}" wx:key="itemId">
      <image class="item-img" src="{{item.imageUrl}}" mode="aspectFill" />
      <view class="item-info">
        <text class="item-name">{{item.name}}</text>
        <text class="item-note" wx:if="{{item.note}}">{{item.note}}</text>
      </view>
      <view class="qty-control">
        <view class="qty-btn" catchtap="minus" data-type="snack" data-index="{{index}}">－</view>
        <text class="qty-num">{{item.quantity}}</text>
        <view class="qty-btn" catchtap="plus" data-type="snack" data-index="{{index}}">＋</view>
      </view>
    </view>
  </view>

  <view style="height: 160rpx;"></view>
</view>

<!-- 底部操作栏 -->
<view class="action-bar" wx:if="{{!loading && order.status !== 'cancelled'}}">
  <view class="btn-cancel" bindtap="cancelOrder">取消订单</view>
  <view class="btn-save {{saving ? 'disabled' : ''}}" bindtap="saveChanges">{{saving ? '保存中...' : '保存修改'}}</view>
</view>
