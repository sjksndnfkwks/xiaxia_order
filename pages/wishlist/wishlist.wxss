.wish-page {
  min-height: 100vh;
  background: var(--c-bg);
  display: flex;
  flex-direction: column;
}

.wish-header {
  background: #FFFFFF;
  padding: 32rpx 32rpx 28rpx;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  border-bottom: 1rpx solid var(--c-border-light);
}

.wish-header-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--c-text-h);
}

.wish-header-sub {
  font-size: 22rpx;
  color: var(--c-text-hint);
}

.wish-list {
  flex: 1;
  padding: 16rpx 0;
}

.loading-wrap {
  text-align: center;
  color: var(--c-text-hint);
  font-size: 26rpx;
  padding: 80rpx 0;
}

.empty-wrap {
  padding: 120rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.empty-title {
  font-size: 30rpx;
  color: var(--c-text-h);
  font-weight: 600;
}

.empty-sub {
  font-size: 24rpx;
  color: var(--c-text-hint);
}

/* 每行 */
.wish-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 24rpx 32rpx;
  background: var(--c-bg-card);
  margin: 12rpx 24rpx;
  border-radius: 16rpx;
  border: 1rpx solid var(--c-border-light);
}

.wish-rank {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: var(--c-bg);
  color: var(--c-text-sub);
  font-size: 24rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.wish-row:nth-child(1) .wish-rank {
  background: #FFD85A;
  color: var(--c-primary);
}

.wish-row:nth-child(2) .wish-rank {
  background: #D9D9D9;
  color: #4A4A4A;
}

.wish-row:nth-child(3) .wish-rank {
  background: #E8B878;
  color: #FFFFFF;
}

.wish-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.wish-name-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.wish-name {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--c-text-h);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  flex-shrink: 1;
  min-width: 0;
}

.wish-cat {
  font-size: 20rpx;
  color: var(--c-text-sub);
  background: var(--c-bg);
  padding: 2rpx 12rpx;
  border-radius: 10rpx;
  flex-shrink: 0;
}

.avatars-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-top: 4rpx;
}

.avatar-stack {
  display: flex;
}

.stack-avatar {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  border: 2rpx solid #FFFFFF;
  background: var(--c-bg);
  margin-left: -10rpx;
}

.stack-avatar:first-child {
  margin-left: 0;
}

.extra-count {
  font-size: 22rpx;
  color: var(--c-text-hint);
  font-weight: 600;
}

.wish-bar-wrap {
  height: 10rpx;
  background: var(--c-bg);
  border-radius: 5rpx;
  overflow: hidden;
}

.wish-bar {
  height: 100%;
  background: linear-gradient(90deg, #FFD85A 0%, #FFB54A 100%);
  border-radius: 5rpx;
}

.wish-level {
  display: flex;
  align-items: baseline;
  gap: 2rpx;
  flex-shrink: 0;
}

.wish-level-num {
  font-size: 36rpx;
  font-weight: 800;
  color: var(--c-primary);
}

.wish-level-unit {
  font-size: 20rpx;
  color: var(--c-text-hint);
}

/* 新增按钮 */
.fab {
  position: fixed;
  right: 40rpx;
  bottom: 60rpx;
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: var(--c-primary);
  color: #FFFFFF;
  font-size: 56rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 6rpx 20rpx rgba(29, 27, 59, 0.25);
}

/* 表单弹窗 */
.form-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.4);
  z-index: 500;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.form-sheet {
  width: 100%;
  background: var(--c-bg-card);
  border-radius: 32rpx 32rpx 0 0;
  padding: 28rpx 32rpx 40rpx;
  box-sizing: border-box;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}

.form-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.form-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--c-text-h);
}

.form-close {
  padding: 8rpx 16rpx;
  font-size: 32rpx;
  color: var(--c-text-sub);
}

.form-field {
  margin-bottom: 28rpx;
}

.field-label {
  font-size: 24rpx;
  color: var(--c-text-sub);
  margin-bottom: 12rpx;
  display: block;
}

.field-input {
  width: 100%;
  height: 80rpx;
  background: var(--c-bg);
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: var(--c-text-h);
  box-sizing: border-box;
  border: 1rpx solid var(--c-border-light);
}

.level-display {
  display: flex;
  align-items: baseline;
  gap: 6rpx;
  margin-bottom: 8rpx;
}

.level-num {
  font-size: 48rpx;
  font-weight: 800;
  color: var(--c-primary);
}

.level-unit {
  font-size: 24rpx;
  color: var(--c-text-hint);
}

.level-hints {
  display: flex;
  justify-content: space-between;
  margin-top: 4rpx;
  padding: 0 8rpx;
}

.hint-left, .hint-right {
  font-size: 22rpx;
  color: var(--c-text-hint);
}

.form-btns {
  display: flex;
  gap: 20rpx;
  margin-top: 16rpx;
}

.btn-save {
  flex: 1;
  height: 88rpx;
  background: var(--c-primary);
  color: #FFFFFF;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-delete {
  width: 140rpx;
  height: 88rpx;
  background: var(--c-bg);
  color: var(--c-accent);
  border-radius: 44rpx;
  font-size: 28rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1rpx solid var(--c-border);
}

.btn-edit {
  width: 140rpx;
  height: 88rpx;
  background: var(--c-bg);
  color: var(--c-primary);
  border-radius: 44rpx;
  font-size: 28rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1rpx solid var(--c-border);
}

.btn-promote {
  background: #FFF7D6;
  color: #8B6F00;
  border-color: #FFD85A;
}

.picker-field {
  display: flex;
  align-items: center;
  color: var(--c-text-h);
}
