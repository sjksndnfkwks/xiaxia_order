/* ============================================
   虾虾的626小食堂 — 史迪仔主题设计系统
   ============================================ */

page {
  /* 主色系：史迪仔深海蓝 */
  --c-primary:        #1B4FD8;
  --c-primary-mid:    #3B6FE8;
  --c-primary-light:  #6B9FFF;
  --c-primary-pale:   #E8EFFE;

  /* 辅助色：星空青 */
  --c-teal:           #00B4D8;
  --c-teal-light:     #90E0EF;

  /* 强调色：史迪仔粉 */
  --c-accent:         #FF6B9D;
  --c-accent-light:   #FFB3CE;

  /* 背景色 */
  --c-bg:             #F2F5FF;
  --c-bg-card:        #FFFFFF;
  --c-bg-deep:        #0D1F6E;

  /* 文字色 */
  --c-text-h:         #0D1F6E;   /* 标题：深蓝 */
  --c-text-body:      #2D3561;   /* 正文：中蓝灰 */
  --c-text-sub:       #7B8AC4;   /* 辅助：浅蓝灰 */
  --c-text-hint:      #B0BDF5;   /* 提示：更浅 */
  --c-text-white:     #FFFFFF;

  /* 边框 */
  --c-border:         #D6DFFF;
  --c-border-light:   #EEF2FF;

  /* 圆角 */
  --r-card:    24rpx;
  --r-btn:     50rpx;
  --r-input:   16rpx;
  --r-tag:     12rpx;

  /* 阴影 */
  --shadow-card:  0 4rpx 24rpx rgba(27, 79, 216, 0.10);
  --shadow-float: 0 8rpx 32rpx rgba(27, 79, 216, 0.18);
  --shadow-btn:   0 6rpx 20rpx rgba(27, 79, 216, 0.30);

  /* 渐变 */
  --grad-primary: linear-gradient(135deg, #1B4FD8 0%, #3B6FE8 50%, #00B4D8 100%);
  --grad-card:    linear-gradient(135deg, #FFFFFF 0%, #F2F5FF 100%);
  --grad-deep:    linear-gradient(160deg, #0D1F6E 0%, #1B4FD8 60%, #00B4D8 100%);

  /* 字体 */
  font-family: -apple-system, 'PingFang SC', 'Noto Sans SC', 'Helvetica Neue', Arial, sans-serif;
  font-size: 28rpx;
  color: var(--c-text-body);
  background-color: var(--c-bg);
  -webkit-font-smoothing: antialiased;
}

/* ── 通用卡片 ── */
.card {
  background: var(--c-bg-card);
  border-radius: var(--r-card);
  box-shadow: var(--shadow-card);
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.card-grad {
  background: var(--grad-card);
  border-radius: var(--r-card);
  box-shadow: var(--shadow-card);
  border: 1rpx solid var(--c-border-light);
}

/* ── 按钮 ── */
.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--r-btn);
  font-size: 30rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
  padding: 22rpx 48rpx;
  border: none;
  outline: none;
  transition: opacity 0.15s;
}
.btn::after { border: none; }

.btn-primary {
  background: var(--grad-primary);
  color: #fff;
  box-shadow: var(--shadow-btn);
}

.btn-accent {
  background: linear-gradient(135deg, #FF6B9D, #FF8FB5);
  color: #fff;
  box-shadow: 0 6rpx 20rpx rgba(255, 107, 157, 0.35);
}

.btn-ghost {
  background: transparent;
  color: var(--c-primary);
  border: 2rpx solid var(--c-primary);
}

/* ── 标题层级（参考 Claude 字体节奏）── */
.title-xl {
  font-size: 48rpx;
  font-weight: 800;
  color: var(--c-text-h);
  letter-spacing: -1rpx;
  line-height: 1.25;
}

.title-lg {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--c-text-h);
  letter-spacing: -0.5rpx;
  line-height: 1.3;
}

.title-md {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--c-text-h);
  line-height: 1.4;
}

.title-sm {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--c-text-body);
  line-height: 1.5;
}

.body-lg { font-size: 30rpx; color: var(--c-text-body); line-height: 1.7; }
.body-md { font-size: 28rpx; color: var(--c-text-body); line-height: 1.7; }
.body-sm { font-size: 24rpx; color: var(--c-text-sub);  line-height: 1.6; }
.caption  { font-size: 22rpx; color: var(--c-text-hint); line-height: 1.5; }

/* ── Section 标题 ── */
.section-title {
  display: flex;
  align-items: center;
  gap: 14rpx;
  font-size: 30rpx;
  font-weight: 700;
  color: var(--c-text-h);
  margin-bottom: 20rpx;
  letter-spacing: 0.5rpx;
}
.section-title::before {
  content: '';
  display: block;
  width: 8rpx;
  height: 36rpx;
  background: var(--grad-primary);
  border-radius: 4rpx;
  flex-shrink: 0;
}

/* ── 状态标签 ── */
.tag {
  display: inline-flex;
  align-items: center;
  padding: 6rpx 20rpx;
  border-radius: var(--r-tag);
  font-size: 22rpx;
  font-weight: 600;
  letter-spacing: 0.5rpx;
}
.tag-pending   { background: #FFF3CD; color: #7D5A00; }
.tag-confirmed { background: #D1F0FF; color: #005F8A; }
.tag-done      { background: #D4F5E2; color: #1A6B3A; }
.tag-cancelled { background: #FFE4E8; color: #8B1A2A; }

/* ── 状态标签（旧命名兼容）── */
.status-tag { display: inline-flex; align-items: center; padding: 6rpx 20rpx; border-radius: var(--r-tag); font-size: 22rpx; font-weight: 600; }
.status-pending   { background: #FFF3CD; color: #7D5A00; }
.status-confirmed { background: #D1F0FF; color: #005F8A; }
.status-done      { background: #D4F5E2; color: #1A6B3A; }
.status-cancelled { background: #FFE4E8; color: #8B1A2A; }

/* ── 分割线 ── */
.divider {
  height: 1rpx;
  background: var(--c-border-light);
  margin: 20rpx 0;
}

/* ── 空状态 ── */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 40rpx;
  gap: 20rpx;
}
.empty-state .empty-icon { font-size: 100rpx; opacity: 0.5; }
.empty-state .empty-text { font-size: 30rpx; color: var(--c-text-sub); font-weight: 500; }
.empty-state .empty-hint { font-size: 24rpx; color: var(--c-text-hint); }

/* ── 加载状态 ── */
.loading-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 80rpx;
  color: var(--c-text-hint);
  font-size: 26rpx;
  gap: 12rpx;
}

/* ── 渐变大标题横幅（各页顶部用）── */
.page-banner {
  background: var(--grad-deep);
  padding: 48rpx 40rpx 56rpx;
  position: relative;
  overflow: hidden;
}
.page-banner::after {
  content: '🐾 ✨ 🐾 ✨ 🐾';
  position: absolute;
  bottom: 12rpx;
  right: 20rpx;
  font-size: 24rpx;
  opacity: 0.25;
  letter-spacing: 8rpx;
}
.page-banner .banner-title {
  font-size: 44rpx;
  font-weight: 800;
  color: #fff;
  letter-spacing: 1rpx;
  display: block;
  margin-bottom: 8rpx;
}
.page-banner .banner-sub {
  font-size: 26rpx;
  color: rgba(255,255,255,0.7);
  display: block;
}

/* ── 输入框通用 ── */
.input-base {
  width: 100%;
  background: var(--c-bg);
  border: 2rpx solid var(--c-border);
  border-radius: var(--r-input);
  padding: 0 24rpx;
  font-size: 28rpx;
  color: var(--c-text-body);
  box-sizing: border-box;
}
.input-base:focus { border-color: var(--c-primary-light); }

/* ── 浮动操作按钮 ── */
.fab {
  position: fixed;
  right: 40rpx;
  bottom: 60rpx;
  width: 104rpx;
  height: 104rpx;
  border-radius: 50%;
  background: var(--grad-primary);
  color: #fff;
  font-size: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: var(--shadow-float);
  line-height: 1;
  z-index: 50;
}
